# Copy this file to .env and fill in real values.
# .env is gitignored — never commit credentials.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# HTTP port for the Rust backend
PORT=3000

# HS256 secret used to sign JWTs — use a long, random value in production
# Generate one with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Set to "true" to enable the /api/auth/dev-login endpoint (dev only)
DEV_MODE=true
